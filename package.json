{
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:dashboard\"",
    "dev:backend": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 --app-dir backend",
    "dev:dashboard": "npm --prefix dashboard run dev",
    "build:dashboard": "npm --prefix dashboard run build",
    "test:dashboard": "npm --prefix dashboard run test"
  },
  "dependencies": {
    "axios": "^1.13.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
